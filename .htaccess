# Block the secret env file
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>
# Hide operator page from search engines
<Files "update.html">
    Header always set X-Robots-Tag "noindex, nofollow"
</Files>
# Short cache for HTML so updates appear fast; long cache for hashed assets
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>
# Block the .git directory from the web
RedirectMatch 404 /\.git
# Team panel (proxied to the codoo-bot Worker; Basic Auth enforced by the Worker)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^(panel|inbox|arrivals|learn|img)(/.*)?$ app.php [L,QSA]
</IfModule>
